{
  "name": "crash-game",
  "private": true,
  "workspaces": [
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "docker:up": "docker compose up",
    "docker:down": "docker compose down",
    "docker:prune": "docker compose down -v --rmi all --remove-orphans && docker volume prune -f"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "bun-types": "latest"
  }
}
